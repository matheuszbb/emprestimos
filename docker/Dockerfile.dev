FROM python:3.14.2-alpine3.23

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV TZ="America/Sao_Paulo"
ENV UV_PROJECT_ENV=/emprestimos/.venv
ENV UV_CACHE_DIR=/emprestimos/.cache/uv
ENV UV_LINK_MODE=copy
ENV UV_VENV_MODE=copy

# Copiar código do projeto
COPY ./emprestimos ./emprestimos

WORKDIR /emprestimos

# Tudo em um único RUN (como na versão original)
RUN apk add --no-cache gettext && \
  pip install --upgrade pip && \
  pip install uv && \
  uv sync --no-install-project --quiet && \
  mkdir -p /emprestimos/static /emprestimos/.cache/uv && \
  adduser --disabled-password --no-create-home duser && \
  chown -R duser:duser /emprestimos/static /emprestimos/.venv /emprestimos/.cache

# Ajustar PATH para usar o venv criado pelo uv
ENV PATH="/emprestimos/.venv/bin:$PATH"

USER duser